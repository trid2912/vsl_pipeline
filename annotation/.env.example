# Copy to .env (or export these) — .env is gitignored.

# Where the recording package lives (final_recording_script.csv, capture_log.csv,
# gloss_annotation_sheet.csv, videos/). If unset, the app auto-detects <repo>/final_corpus/recording,
# else falls back to the bundled sample_data/recording for a demo.
ANNOTATION_DATA_DIR=/absolute/path/to/recording

# Single shared login. If neither is set, the app runs OPEN (localhost only!).
ANNOTATION_USER=admin
ANNOTATION_PASSWORD=change-me-strong
# (alternatively set the password via:  python3 annotation_server.py setpassword  -> auth/password.txt)

# Fixed session-signing key so logins survive restarts (else a random per-run key is used).
ANNOTATION_SECRET=generate-with-python-secrets-token_hex-32

# Set to 1 ONLY when served behind HTTPS (marks the session cookie Secure).
ANNOTATION_SECURE=0
